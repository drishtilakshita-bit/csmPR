# Metabase connection (required for metrics API)
# Use the base URL only (no /question/... path). Limechat: https://metabase.limechat.ai
# Create an API key in Metabase: Admin → Settings → Authentication → API Keys
METABASE_SITE_URL=https://metabase.limechat.ai
METABASE_API_KEY=

# Report email (Scaler).
# 413 Request Entity Too Large: use SCALER_SEND_AS_MULTIPART=true (multipart file parts, smaller than JSON+base64),
# or increase nginx client_max_body_size on the Scaler host. Attachment JSON must stay lean (one base64 per file in app).
# Public base URL for “download Excel” links in report emails (avoid localhost). Example: https://your-app.vercel.app
REPORT_PUBLIC_ORIGIN=
# Signed Excel download links: optional; defaults to HMAC with SCALER_INTERNAL_PASS if unset.
REPORT_FILE_DOWNLOAD_SECRET=
SCALER_INTERNAL_PASS=
SCALER_SEND_URL=https://nik-django-canr.limechat.ai/api/v1/send/
SCALER_SEND_AS_MULTIPART=false
# JSON key for base64 attachments (default: attachments). Some APIs use email_attachments.
SCALER_ATTACHMENTS_JSON_KEY=
SCALER_MULTIPART_FILE_FIELD=files
